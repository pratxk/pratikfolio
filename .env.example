# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# MongoDB Atlas connection string + the database to use for the portfolio.
MONGODB_URI=
MONGODB_DB=pratikfolio

# Random secret for signing admin JWT session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Admin login, consumed by scripts/seed.js (password is bcrypt-hashed at seed time).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary (image uploads).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
